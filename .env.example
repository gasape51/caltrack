# Copiez ce fichier en `.env` localement, puis renseignez vos valeurs.
# Ne commitez jamais le fichier `.env`.

YAZIO_EMAIL=votre@email.com
YAZIO_PASSWORD=votre_mot_de_passe

GARMIN_EMAIL=votre@email.com
GARMIN_PASSWORD=votre_mot_de_passe
GARMIN_TOKEN_DIR=~/.garminconnect

DEFICIT_GOAL=500
STEPS_GOAL=10000
STATS_START_DATE=

HOST=0.0.0.0
PORT=5000
DEBUG=false

CACHE_TTL_TODAY=120
CACHE_TTL_PAST=3600
